<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:browser="http://namespaces.zope.org/browser"
    i18n_domain="{{ package_name }}">

  <browser:viewlet
      name="{{ viewlet_name }}"
      for="{{ viewlet_for }}"
      manager="{{ viewlet_manager }}"
      class=".{{ viewlet_module }}.{{ viewlet_class_name }}"
      permission="zope2.View"
      />

</configure>
