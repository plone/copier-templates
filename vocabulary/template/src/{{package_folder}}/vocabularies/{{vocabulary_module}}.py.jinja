{%- if vocabulary_type == 'catalog' %}
from plone.app.vocabularies.catalog import StaticCatalogVocabulary
from zope.interface import implementer
from zope.schema.interfaces import IVocabularyFactory


@implementer(IVocabularyFactory)
class {{ vocabulary_class }}:
    """Factory for the ``{{ package_name }}.{{ vocabulary_class }}`` vocabulary.

    Returns terms from a catalog query. Adjust the ``query`` dict and
    ``title_template`` to match your use case.
    """

    def __call__(self, context):
        return StaticCatalogVocabulary(
            {
                "portal_type": [
                    "Document",
                ],
            },
            title_template="{brain.Title}",
        )


{{ vocabulary_class }}Factory = {{ vocabulary_class }}()
{%- else %}
from zope.interface import implementer
from zope.schema.interfaces import IVocabularyFactory
from zope.schema.vocabulary import SimpleTerm
from zope.schema.vocabulary import SimpleVocabulary


class VocabItem:
    """Lightweight holder for a (token, value) pair."""

    def __init__(self, token, value):
        self.token = token
        self.value = value


@implementer(IVocabularyFactory)
class {{ vocabulary_class }}:
    """Factory for the ``{{ package_name }}.{{ vocabulary_class }}`` vocabulary.

    Replace the hardcoded ``items`` list with whatever source your vocabulary
    needs (portal catalog query, external service, registry, etc.).
    """

    def __call__(self, context):
        items = [
            VocabItem("example-token", "Example value"),
        ]
        terms = [
            SimpleTerm(value=item.token, token=item.token, title=item.value)
            for item in items
        ]
        return SimpleVocabulary(terms)


{{ vocabulary_class }}Factory = {{ vocabulary_class }}()
{%- endif %}
